{{define "page:title"}}Login | TotalComp MX{{end}}

{{define "page:main"}}
<div style="min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 2rem; box-sizing: border-box;">
    <div style="width: 100%; max-width: 450px;">
        <!-- Logo/Branding -->
        <div style="text-align: center; margin-bottom: 2rem;">
            <div style="font-size: 3rem; margin-bottom: 0.5rem;">💰</div>
            <h1 style="color: white; font-size: 1.75rem; font-weight: 700; margin: 0 0 0.5rem 0;">
                TotalComp MX
            </h1>
            <p style="color: #94a3b8; font-size: 0.875rem; margin: 0;">
                Inicia sesión para acceder a tu cuenta
            </p>
        </div>

        <!-- Login Card -->
        <div style="background: #1e293b; padding: 2rem; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.3); border: 1px solid #334155;">
            <h2 style="color: white; font-size: 1.5rem; font-weight: 700; margin: 0 0 1.5rem 0; text-align: center;">
                Iniciar Sesión
            </h2>

            <!-- Global Error Message -->
            {{if .Form.Validator.HasErrors}}
            <div style="background: #fee2e2; border-left: 4px solid #ef4444; padding: 1rem; border-radius: 6px; margin-bottom: 1.5rem;">
                <p style="color: #991b1b; font-weight: 600; margin: 0 0 0.25rem 0; font-size: 0.875rem;">
                    ⚠️ Credenciales incorrectas
                </p>
                <p style="color: #7f1d1d; margin: 0; font-size: 0.75rem;">
                    Por favor verifica tu email y contraseña.
                </p>
            </div>
            {{end}}

            <form method="POST" action="/login">
                <input type='hidden' name='csrf_token' value='{{.CSRFToken}}'>
                
                <!-- Email Field -->
                <div style="margin-bottom: 1.25rem;">
                    <label style="display: block; color: #f8fafc; font-weight: 600; margin-bottom: 0.5rem; font-size: 0.875rem;">
                        📧 Email
                    </label>
                    <input 
                        type="email" 
                        name="Email" 
                        value="{{.Form.Email}}"
                        placeholder="tu@email.com"
                        class="tc-focus-indigo"
                        style="width: 100%; padding: 0.75rem; background: #0f172a; border: 2px solid {{template "login:border-color" .Form.Validator.FieldErrors.Email}}; border-radius: 8px; color: #f8fafc; font-size: 0.875rem; box-sizing: border-box; outline: none; transition: border-color 0.2s;"
                        required
                        autofocus>
                    {{template "login:field-error" .Form.Validator.FieldErrors.Email}}
                </div>

                <!-- Password Field -->
                <div style="margin-bottom: 1rem;">
                    <label style="display: block; color: #f8fafc; font-weight: 600; margin-bottom: 0.5rem; font-size: 0.875rem;">
                        🔒 Contraseña
                    </label>
                    <input 
                        type="password" 
                        name="Password"
                        placeholder="Tu contraseña"
                        class="tc-focus-indigo"
                        style="width: 100%; padding: 0.75rem; background: #0f172a; border: 2px solid {{template "login:border-color" .Form.Validator.FieldErrors.Password}}; border-radius: 8px; color: #f8fafc; font-size: 0.875rem; box-sizing: border-box; outline: none; transition: border-color 0.2s;"
                        required>
                    {{template "login:field-error" .Form.Validator.FieldErrors.Password}}
                </div>

                <!-- Forgot Password Link -->
                <div style="text-align: right; margin-bottom: 1.5rem;">
                    <a href="/forgotten-password" class="tc-hover-indigo-link-underline" style="color: #6366f1; text-decoration: none; font-size: 0.75rem; font-weight: 600; transition: color 0.2s;">
                        ¿Olvidaste tu contraseña?
                    </a>
                </div>

                <!-- Submit Button -->
                <button 
                    type="submit"
                    class="tc-hover-raise-indigo-shadow"
                    style="width: 100%; background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); color: white; border: none; padding: 0.875rem; border-radius: 8px; font-weight: 700; font-size: 1rem; cursor: pointer; box-shadow: 0 4px 6px rgba(99, 102, 241, 0.3); transition: transform 0.2s, box-shadow 0.2s; box-sizing: border-box;"
                    >
                    🔑 Iniciar Sesión
                </button>
            </form>

            <!-- Divider -->
            <div style="margin: 1.5rem 0; text-align: center; position: relative;">
                <div style="position: absolute; top: 50%; left: 0; right: 0; height: 1px; background: #334155;"></div>
                <span style="position: relative; background: #1e293b; padding: 0 1rem; color: #64748b; font-size: 0.75rem; font-weight: 600;">
                    O
                </span>
            </div>

            <!-- Signup Link -->
            <div style="text-align: center;">
                <p style="color: #94a3b8; font-size: 0.875rem; margin: 0;">
                    ¿No tienes cuenta?
                    <a href="/signup" class="tc-hover-green-link-underline" style="color: #10b981; text-decoration: none; font-weight: 600; transition: color 0.2s;">
                        Regístrate gratis
                    </a>
                </p>
            </div>
        </div>

        <!-- Back to Home Link -->
        <div style="text-align: center; margin-top: 1.5rem;">
            <a href="/" class="tc-hover-muted-link" style="color: #64748b; text-decoration: none; font-size: 0.875rem; transition: color 0.2s;">
                ← Volver al inicio
            </a>
        </div>
    </div>
</div>
{{end}}

{{define "login:border-color"}}
{{if .}}#ef4444{{else}}#334155{{end}}
{{end}}

{{define "login:field-error"}}
{{with .}}
<p style="color: #ef4444; font-size: 0.75rem; margin: 0.5rem 0 0 0; font-weight: 500;">
    ❌ {{.}}
</p>
{{end}}
{{end}}
