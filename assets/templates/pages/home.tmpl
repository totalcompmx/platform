    <td style="padding: 0.5rem 0; color: #64748b;">🏖️ Prima Vacacional (neto)</td>
    <td style="padding: 0.5rem 0; text-align: right; color: #059669; font-weight: 600;">${{formatFloat .PrimaVacacionalNet 2}}</td>
</tr>
{{end}}
{{end}}

{{define "home:fondo-yearly-row"}}
{{if .FondoAhorroYearly}}
<tr style="border-bottom: 1px solid #e2e8f0;">
