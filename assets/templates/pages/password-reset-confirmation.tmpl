{{define "page:title"}}Contraseña Actualizada | TotalComp MX{{end}}

{{define "page:main"}}
<div style="min-height: 80vh; display: flex; align-items: center; justify-content: center; padding: 2rem; box-sizing: border-box;">
    <div style="width: 100%; max-width: 500px;">
        <!-- Success Icon -->
        <div style="text-align: center; margin-bottom: 2rem;">
            <div style="display: inline-block; background: linear-gradient(135deg, #10b981 0%, #059669 100%); width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 10px 25px rgba(16, 185, 129, 0.3); margin-bottom: 1rem;">
                <span style="font-size: 3rem;">✅</span>
            </div>
            <h1 style="color: white; font-size: 2rem; font-weight: 700; margin: 0 0 0.5rem 0;">
                ¡Contraseña Actualizada!
            </h1>
            <p style="color: #94a3b8; font-size: 1rem; margin: 0;">
                Tu contraseña ha sido restablecida exitosamente
            </p>
        </div>

        <!-- Confirmation Card -->
        <div style="background: #1e293b; padding: 2rem; border-radius: 12px; box-shadow: 0 10px 25px rgba(0,0,0,0.3); border: 1px solid #334155;">
            <p style="color: #f8fafc; font-size: 0.875rem; line-height: 1.8; margin: 0 0 1.5rem 0; text-align: center;">
                Ya puedes iniciar sesión con tu nueva contraseña.
            </p>

            <!-- Success Box -->
            <div style="background: #ecfdf5; padding: 1.5rem; border-radius: 8px; border-left: 4px solid #10b981; margin-bottom: 1.5rem;">
                <p style="color: #065f46; font-size: 0.875rem; margin: 0; line-height: 1.6; font-weight: 600;">
                    🔒 Seguridad
                </p>
                <p style="color: #047857; font-size: 0.75rem; margin: 0.5rem 0 0 0; line-height: 1.6;">
                    Tu contraseña ha sido encriptada y almacenada de forma segura. Te recomendamos usar una contraseña única para TotalComp MX.
                </p>
            </div>

            <!-- CTA Button -->
            <a href="/login" class="tc-hover-raise-indigo-shadow" style="display: block; background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%); color: white; padding: 1rem; border-radius: 8px; text-decoration: none; font-weight: 700; font-size: 1rem; text-align: center; box-shadow: 0 4px 6px rgba(99, 102, 241, 0.3); transition: transform 0.2s, box-shadow 0.2s;">
                🔑 Iniciar Sesión Ahora
            </a>

            <!-- Divider -->
            <div style="margin: 1.5rem 0; text-align: center; position: relative;">
                <div style="position: absolute; top: 50%; left: 0; right: 0; height: 1px; background: #334155;"></div>
                <span style="position: relative; background: #1e293b; padding: 0 1rem; color: #64748b; font-size: 0.75rem; font-weight: 600;">
                    O
                </span>
            </div>

            <!-- Secondary Action -->
            <div style="text-align: center;">
                <a href="/" class="tc-hover-light-link-underline" style="color: #94a3b8; text-decoration: none; font-size: 0.875rem; transition: color 0.2s;">
                    🏠 Volver al inicio
                </a>
            </div>
        </div>

        <!-- Additional Help -->
        <div style="text-align: center; margin-top: 2rem;">
            <p style="color: #64748b; font-size: 0.75rem; line-height: 1.6;">
                ¿Tienes problemas para iniciar sesión?<br>
                Contacta a <a href="mailto:hola@totalcomp.mx" style="color: #10b981; text-decoration: underline;">hola@totalcomp.mx</a>
            </p>
        </div>
    </div>
</div>
{{end}}
