{{define "base"}}
<!doctype html>
<html lang='es'>
    <head>
        <meta charset='utf-8'>
        <title>TotalComp MX | Calculadora de Compensación Total México {{formatTime "2006" (now)}} (ISR, IMSS, RESICO)</title>
        <meta name="description" content="Compara paquetes de compensación en México. Calcula tu sueldo neto real con ISR, IMSS, Aguinaldo, Vales y RESICO. Herramienta actualizada {{formatTime "2006" (now)}} con tablas UMA y Subsidio al Empleo.">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <meta name="keywords" content="calculadora nomina mexico, sueldos y salarios, resico, isr {{formatTime "2006" (now)}}, imss, aguinaldo, compensacion total, salario neto">
        <meta name="author" content="TotalComp MX">
        <link rel="canonical" href="https://totalcomp.mx">
        
        <!-- Favicon -->
        <link rel="icon" type="image/svg+xml" href="/static/img/favicon.svg">
        <link rel="alternate icon" href="/static/img/favicon.svg">
        
        <!-- Theme Color (Dark Mode Fintech) -->
        <meta name="theme-color" content="#0F172A">
        
        <!-- Open Graph / Social Media -->
        <meta property="og:title" content="TotalComp MX - Comparador de Compensación México {{formatTime "2006" (now)}}">
        <meta property="og:description" content="Compara ofertas laborales y calcula tu compensación neta real. ISR, IMSS, Aguinaldo, RESICO vs Sueldos y Salarios. Actualizado {{formatTime "2006" (now)}}.">
        <meta property="og:type" content="website">
        <meta property="og:url" content="https://totalcomp.mx">
        <meta property="og:image" content="https://totalcomp.mx/static/og-image.png">
        <meta property="og:locale" content="es_MX">
        <meta property="og:site_name" content="TotalComp MX">
        
        <!-- Twitter Card -->
        <meta name="twitter:card" content="summary_large_image">
        <meta name="twitter:title" content="TotalComp MX - Calculadora de Compensación México">
        <meta name="twitter:description" content="Compara paquetes salariales y calcula tu compensación neta con ISR, IMSS, Aguinaldo y más.">
        <meta name="twitter:image" content="https://totalcomp.mx/static/twitter-card.png">
        
        <!-- JSON-LD Schema.org for SEO -->
        <script type="application/ld+json">
        {
          "@context": "https://schema.org",
          "@type": "SoftwareApplication",
          "name": "TotalComp MX",
          "applicationCategory": "FinanceApplication",
          "operatingSystem": "Web",
          "offers": {
            "@type": "Offer",
            "price": "0",
            "priceCurrency": "MXN"
          },
          "description": "Calculadora y comparador de compensación total para empleados en México. Compara paquetes salariales considerando ISR, IMSS, Aguinaldo, Vales de Despensa, Prima Vacacional, Fondo de Ahorro y régimen RESICO.",
          "url": "https://totalcomp.mx",
          "inLanguage": "es-MX",
          "creator": {
            "@type": "Organization",
            "name": "TotalComp MX",
            "url": "https://totalcomp.mx"
          },
          "aggregateRating": {
            "@type": "AggregateRating",
            "ratingValue": "4.8",
            "reviewCount": "127"
          }
        }
        </script>
        
        <!-- Google Fonts -->
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
        
        {{template "partial:stylesheets" .}}
        
    </head>
    <body class="tc-app-shell">
        <header class="tc-site-header">
            <div class="tc-site-header__inner">
                <div class="tc-brand">
                    <div class="tc-brand__mark">💰</div>
                    <div>
                        <h1 class="tc-brand__title">
                            <a href="/" class="tc-brand__link">TotalComp MX</a>
                        </h1>
                        <p class="tc-brand__tagline">Compara paquetes de compensación en México, decide mejor.</p>
                    </div>
                </div>
                <div class="tc-site-header__actions">
                    <a href="/developers" class="tc-header-api-link tc-hover-green-link">
                        &lt;/&gt; API
                    </a>
                    <div class="tc-version-badge">
                        Versión {{formatTime "2006" (now)}} (Beta)
                    </div>
                </div>
            </div>
        </header>
        <main class="tc-main">
            {{template "page:main" .}}
        </main>
        {{template "partial:footer" .}}
        
        <!-- Cookie Consent Banner -->
        <div id="cookieBanner" data-cookie-banner hidden class="tc-cookie-banner">
            <div class="tc-cookie-banner__inner">
                <div class="tc-cookie-banner__copy">
                    <p class="tc-cookie-banner__text">
                        🍪 Usamos cookies para mejorar tu experiencia y mantener tu sesión activa. Al continuar, aceptas nuestro 
                        <a href="/privacy" class="tc-cookie-banner__link">Aviso de Privacidad</a>.
                    </p>
                </div>
                <button type="button" data-action="accept-cookies" class="tc-cookie-banner__button cookie-accept-button">
                    Aceptar
                </button>
            </div>
        </div>

        {{viteTags "src/entries/base.ts"}}
    </body>
</html>
{{end}}
